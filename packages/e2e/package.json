{
  "name": "e2e",
  "version": "0.0.0-dev",
  "license": "MIT",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "e2e": "test-with-playwright --only-extension=./extension --test-path=. --server-path=../server/src/server.js --reuse-page",
    "e2e:firefox": "npm run patch:playwright-firefox-worker-websocket && test-with-playwright --only-extension=./extension --test-path=. --server-path=../server/src/server.js --reuse-page --browser=firefox",
    "e2e:firefox:headless": "npm run patch:playwright-firefox-worker-websocket && test-with-playwright --only-extension=./extension --test-path=. --server-path=../server/src/server.js --reuse-page --browser=firefox --headless",
    "e2e:headless": "test-with-playwright --only-extension=./extension --test-path=. --server-path=../server/src/server.js --reuse-page --headless",
    "e2e:webkit": "test-with-playwright --only-extension=./extension --test-path=. --server-path=../server/src/server.js --reuse-page --browser=webkit",
    "e2e:webkit:headless": "test-with-playwright --only-extension=./extension --test-path=. --server-path=../server/src/server.js --reuse-page --browser=webkit --headless",
    "patch:playwright-firefox-worker-websocket": "node ./scripts/patch-playwright-firefox-worker-websocket.js",
    "type-check": "tsc"
  },
  "devDependencies": {
    "@lvce-editor/test-with-playwright": "^22.8.1"
  }
}
