{
  "name": "@lvce-editor/quick-pick-worker-monorepo",
  "version": "0.0.0-dev",
  "license": "MIT",
  "author": "Lvce Editor",
  "type": "module",
  "scripts": {
    "build": "node packages/build/src/build.js",
    "build:static": "node packages/build/src/build-static.js",
    "build:watch": "./packages/build/node_modules/.bin/esbuild --format=esm --bundle --sourcemap --external:node:buffer --external:electron --external:ws --external:node:worker_threads --watch packages/quick-pick-worker/src/quickPickWorkerMain.ts --outfile=.tmp/dist/dist/quickPickWorkerMain.js",
    "dev": "node packages/build/src/dev.js",
    "e2e": "cd packages/e2e && npm run e2e",
    "e2e:firefox": "cd packages/e2e && npm run e2e:firefox",
    "e2e:firefox:headless": "cd packages/e2e && npm run e2e:firefox:headless",
    "e2e:headless": "cd packages/e2e && npm run e2e:headless",
    "e2e:webkit": "cd packages/e2e && npm run e2e:webkit",
    "e2e:webkit:headless": "cd packages/e2e && npm run e2e:webkit:headless",
    "format": "prettier --write .",
    "postinstall": "lerna bootstrap --ci",
    "lint": "eslint . && prettier --check .",
    "test": "lerna run test",
    "type-check": "tsc -b"
  },
  "prettier": {
    "semi": false,
    "singleQuote": true,
    "printWidth": 150
  },
  "devDependencies": {
    "@lerna/legacy-package-management": "^8.2.4",
    "@lvce-editor/eslint-config": "^14.2.0",
    "eslint": "^10.6.0",
    "lerna": "^8.2.4",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3"
  }
}
