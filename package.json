{
  "name": "@lvce-editor/quick-pick-worker-monorepo",
  "version": "0.0.0-dev",
  "license": "MIT",
  "author": "Lvce Editor",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "node packages/build/src/build.js",
    "build:static": "node packages/build/src/build-static.js",
    "build:watch": "npm exec --workspace=packages/build -- esbuild --format=esm --bundle --sourcemap --external:node:buffer --external:electron --external:ws --external:node:worker_threads --watch packages/quick-pick-worker/src/quickPickWorkerMain.ts --outfile=.tmp/dist/dist/quickPickWorkerMain.js",
    "dev": "node packages/build/src/dev.js",
    "e2e": "npm run e2e --workspace=packages/e2e",
    "e2e:firefox": "npm run e2e:firefox --workspace=packages/e2e",
    "e2e:firefox:headless": "npm run e2e:firefox:headless --workspace=packages/e2e",
    "e2e:headless": "npm run e2e:headless --workspace=packages/e2e",
    "e2e:webkit": "npm run e2e:webkit --workspace=packages/e2e",
    "e2e:webkit:headless": "npm run e2e:webkit:headless --workspace=packages/e2e",
    "format": "prettier --write .",
    "lint": "eslint . && prettier --check .",
    "test": "npm test --workspaces --if-present",
    "type-check": "tsc -b"
  },
  "prettier": {
    "semi": false,
    "singleQuote": true,
    "printWidth": 150
  },
  "devDependencies": {
    "@lvce-editor/eslint-config": "^17.1.0",
    "@lvce-editor/eslint-plugin-virtual-dom": "^13.7.0",
    "eslint": "^10.7.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3"
  }
}
